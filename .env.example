# OpenAI API Configuration
# https://platform.openai.com/account/api-keys 에서 발급받은 키를 입력
OPENAI_API_KEY=

# Tavily Search API Configuration
# https://app.tavily.com 에서 발급받은 키를 입력
TAVILY_API_KEY=

# RAG 재검색 루프(Agentic RAG) on/off — 기본 false=plain 단발 검색
# 근거: docs/adr/0001-rag-default-plain.md (현 코퍼스에선 재검색 순이득 없음)
# 더 크고 노이즈 많은 코퍼스/약한 검색기로 교체 시 true 권장
RAG_AGENTIC=false